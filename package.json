{
  "name": "smart-agro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "BASE_PATH=/smart-agro/ tsc -b && vite build",
    "preview:pages": "npm run build:pages && vite preview --base /smart-agro/",
    "lint": "eslint .",
    "preview": "vite preview",
    "import:plantvillage": "node scripts/import-plantvillage.mjs",
    "import:upm": "node scripts/import-upm-sayur.mjs",
    "import:agencies": "node scripts/import-agency-sources.mjs",
    "import:data": "npm run import:plantvillage && npm run import:upm && npm run import:agencies"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
